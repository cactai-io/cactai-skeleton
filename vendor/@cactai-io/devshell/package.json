{
  "name": "@cactai-io/devshell",
  "version": "1.4.9",
  "private": true,
  "description": "Cactai DevShell — the IDE client mounted at /dev in preview deployments of the skeleton. Distributed as a private package; consumed via dynamic import gated on VERCEL_ENV !== 'production' so the code is never present in production builds.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@cactai-io/client": "^1.4.0",
    "@cactai-io/primitives": "^1.4.0",
    "@cactai-io/themes": "^1.4.0",
    "@cactai-io/types": "^1.4.9",
    "@cactai-io/mui": "file:../mui"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
