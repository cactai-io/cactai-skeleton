{
  "name": "@cactai-io/mui",
  "version": "0.1.1",
  "type": "module",
  "private": true,
  "license": "MIT",
  "description": "Cactai MUI implementation — agentic UI rendering system.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sdk-manifest": {
      "import": "./dist/sdk-manifest.js",
      "types": "./dist/sdk-manifest.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@cactai-io/types": "workspace:*",
    "@cactai-io/themes": "workspace:*",
    "@cactai-io/brand-tokens": "workspace:*",
    "react": "^19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "dompurify": "^3.0.0",
    "monaco-editor": "^0.52.0",
    "@monaco-editor/react": "^4.6.0",
    "diff": "^5.2.0",
    "react-diff-viewer-continued": "^3.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.5.0",
    "@types/dompurify": "^3.0.0",
    "@types/diff": "^5.2.0"
  }
}
