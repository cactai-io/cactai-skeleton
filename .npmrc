@cactai-io:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${CACTAI_NPM_TOKEN}

# pnpm 11 ships a supply-chain freshness check (minimumReleaseAge) that
# rejects packages published within the configured window. The default
# protection is appropriate for third-party deps. The skeleton's per-
# developer Vercel build installs @cactai-io/* from GitHub Packages on
# every fresh publish — without this exclusion, every customer Vercel
# build would stall for hours after we publish a new SDK release.
# First-party scope only; third-party protection stays intact.
minimum-release-age-exclude=@cactai-io/*
