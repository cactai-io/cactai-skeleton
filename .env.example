# Per-project platform key (minted in the Cactai Console; server-only — never NEXT_PUBLIC)
CACTAI_API_KEY=
# Your project id (safe for the browser)
NEXT_PUBLIC_CACTAI_PROJECT_ID=
# Platform endpoints (defaults shown)
NEXT_PUBLIC_CACTAI_BASE_URL=https://api.cactai.io
NEXT_PUBLIC_CACTAI_ID_URL=https://id.cactai.io
