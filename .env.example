# .env.example — copy to .env.local for local development.
# All variables are written to Vercel during automated provisioning.
# Never commit .env.local to git.

# Section: Cactai Platform
# Per-project API key — issued by Cactai after provisioning.
CACTAI_API_KEY=

# Stable project identifier — written by provisioning wizard.
NEXT_PUBLIC_CACTAI_PROJECT_ID=

# Cactai platform API base URL — do not change unless self-hosting.
CACTAI_BASE_URL=https://api.cactai.io
NEXT_PUBLIC_CACTAI_BASE_URL=https://api.cactai.io

# Section: AI Model
# Model provider — anthropic or openai
CACTAI_MODEL_PROVIDER=anthropic

# Anthropic API key — BYO, never stored on Cactai servers.
ANTHROPIC_API_KEY=

# OpenAI API key — required if using OpenAI as provider.
OPENAI_API_KEY=

# Section: Supabase (production)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Section: Secrets encryption
# Symmetric key used to encrypt end-user BYOK provider keys before storage
# in customer DB. Must match the platform's SECRETS_ENCRYPTION_KEY so the
# platform can decrypt rows written by the skeleton. 64 hex chars / 32 bytes.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRETS_ENCRYPTION_KEY=

# Section: Supabase (dev/preview)
NEXT_PUBLIC_SUPABASE_URL_DEV=
NEXT_PUBLIC_SUPABASE_ANON_KEY_DEV=
SUPABASE_SERVICE_KEY_DEV=

# Section: GitHub
# PAT or OAuth token — used by the dev agent to read/write files.
GITHUB_TOKEN=
GITHUB_REPO_NAME=

# Section: Vercel
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=

# Section: App
NEXT_PUBLIC_APP_URL=

# Friendly product name used in transactional emails (invitations, etc.)
# and any UI surface that addresses "the app" by name. Falls back to
# 'the app' when unset.
NEXT_PUBLIC_APP_NAME=

# Section: Auth Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Section: Dev account (used by scripts/seed.ts)
DEV_ACCOUNT_EMAIL=

# Section: GitHub Packages
# Read-only token for installing @cactai-io/* packages.
# Provisioned apps have this set automatically by the wizard.
# For local dev: get the shared token from your team's secrets manager.
CACTAI_NPM_TOKEN=

# Section: Feature flags
# Gates the _studio/preview route. 404 when unset/false; 200 when 'true'.
# Intended for design-review previews, not production traffic.
STUDIO_PREVIEW_ENABLED=

# Section: Vercel-injected (provided automatically by Vercel at runtime;
# documented here for local-dev parity)
# VERCEL_ENV / VERCEL_URL / NEXT_PUBLIC_VERCEL_ENV are set by the Vercel
# build pipeline. For local dev with `next dev`, leave unset (the app
# guards against missing values). For local previews of preview-env
# behavior, mimic: NEXT_PUBLIC_VERCEL_ENV=preview.
VERCEL_ENV=
VERCEL_URL=
NEXT_PUBLIC_VERCEL_ENV=
