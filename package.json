{
  "name": "cactai-skeleton",
  "version": "1.3.5",
  "private": true,
  "description": "Cactai app template. Fork this repo to start building. You own this code after forking. Imports rendering primitives and the platform HTTP client; all agent logic and IP lives on the Cactai platform server.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx scripts/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cactai-io/primitives":   "^1.0.0",
    "@cactai-io/themes":       "^1.0.0",
    "@cactai-io/types":        "^1.0.0",
    "@cactai-io/client":       "^1.0.0",
    "@cactai-io/brand-tokens": "^0.1.0",
    "@cactai-io/core":         "^1.0.0",
    "@cactai-io/mui":          "^0.1.0",
    "@cactai-io/shell-ui":     "^0.1.0",
    "@supabase/supabase-js": "^2.43.0",
    "@supabase/ssr":         "^0.5.0",
    "@babel/runtime":        "^7.24.0",
    "next":                  "^15.0.0",
    "react":                 "^19.0.0",
    "react-dom":             "^19.0.0",
    "server-only":           "^0.0.1"
  },
  "devDependencies": {
    "@cactai-io/devshell": "1.3.5",
    "@types/node":      "^20.0.0",
    "@types/react":     "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx":              "^4.11.0",
    "typescript":       "^5.5.0",
    "vitest":           "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0"
  },
  "pnpm": {
    "overrides": {
      "@cactai-io/primitives":   "link:../cactai-platform/packages/primitives",
      "@cactai-io/themes":       "link:../cactai-platform/packages/themes",
      "@cactai-io/types":        "link:../cactai-platform/packages/types",
      "@cactai-io/client":       "link:../cactai-platform/packages/client",
      "@cactai-io/devshell":     "link:../cactai-platform/packages/devshell",
      "@cactai-io/shell-ui":     "link:../cactai-platform/packages/shell-ui",
      "@cactai-io/brand-tokens": "link:../cactai-platform/packages/brand-tokens",
      "@cactai-io/mui":          "link:../cactai-platform/packages/mui",
      "@cactai-io/core":         "link:../cactai-platform/packages/core"
    }
  }
}
